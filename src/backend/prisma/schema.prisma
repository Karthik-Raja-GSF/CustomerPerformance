enum PromptStatus {
  ACTIVE
  INACTIVE

  @@schema("ait")
}

model Prompt {
  id        String       @id @default(uuid())
  name      String
  content   String       @db.Text
  model     String
  status    PromptStatus @default(INACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("prompts")
  @@schema("ait")
}
