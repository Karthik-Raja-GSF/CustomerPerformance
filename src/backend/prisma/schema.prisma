// ============================================
// AIT SCHEMA - AI Transformation Tables
// ============================================

enum PromptStatus {
  ACTIVE
  INACTIVE

  @@schema("ait")
}

enum BidExportType {
  CSV
  SIQ

  @@schema("ait")
}

model Prompt {
  id        String       @id @default(uuid())
  name      String
  content   String       @db.Text
  model     String
  status    PromptStatus @default(INACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("prompts")
  @@schema("ait")
}

model CustomerBidData {
  // Composite primary key
  sourceDb       String @map("source_db")
  siteCode       String @map("site_code")
  customerBillTo String @map("customer_bill_to")
  itemNo         String @map("item_no")
  schoolYear     String @map("school_year") // "2025-2026"

  // Pre-calculated fields (populated by sync job)
  bidQty         Decimal? @map("bid_qty")
  lastYearBidQty Decimal? @map("last_year_bid_qty")
  lastYearActual Decimal? @map("last_year_actual")
  lyAugust       Decimal? @map("ly_august")
  lySeptember    Decimal? @map("ly_september")
  lyOctober      Decimal? @map("ly_october")
  lyNovember     Decimal? @map("ly_november")
  lyDecember     Decimal? @map("ly_december")
  lyJanuary      Decimal? @map("ly_january")
  lyFebruary     Decimal? @map("ly_february")
  lyMarch        Decimal? @map("ly_march")
  lyApril        Decimal? @map("ly_april")
  lyMay          Decimal? @map("ly_may")
  lyJune         Decimal? @map("ly_june")
  lyJuly         Decimal? @map("ly_july")
  isLost         Boolean  @default(false) @map("is_lost")
  bidStart       DateTime? @map("bid_start")
  bidEnd         DateTime? @map("bid_end")
  erpStatus      String?   @map("erp_status")

  // User-editable fields
  yearAround      Boolean  @default(false) @map("year_around")

  // Monthly estimates - nullable decimal for each month
  estimateJan Decimal? @map("estimate_jan")
  estimateFeb Decimal? @map("estimate_feb")
  estimateMar Decimal? @map("estimate_mar")
  estimateApr Decimal? @map("estimate_apr")
  estimateMay Decimal? @map("estimate_may")
  estimateJun Decimal? @map("estimate_jun")
  estimateJul Decimal? @map("estimate_jul")
  estimateAug Decimal? @map("estimate_aug")
  estimateSep Decimal? @map("estimate_sep")
  estimateOct Decimal? @map("estimate_oct")
  estimateNov Decimal? @map("estimate_nov")
  estimateDec Decimal? @map("estimate_dec")

  // Last updated tracking
  lastUpdatedAt DateTime? @map("last_updated_at")
  lastUpdatedBy String?   @map("last_updated_by")

  // Confirmation fields (confirmed_at IS NOT NULL = confirmed)
  confirmedBy String?   @map("confirmed_by")
  confirmedAt DateTime? @map("confirmed_at")

  // Export tracking (last_exported_at IS NOT NULL = exported)
  lastExportedAt DateTime? @map("last_exported_at")
  lastExportedBy String?   @map("last_exported_by")

  syncedAt    DateTime? @map("synced_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  exportItems CustomerBidExportItem[]

  @@id([sourceDb, siteCode, customerBillTo, itemNo, schoolYear])
  @@index([schoolYear])
  @@index([confirmedAt])
  @@index([isLost])
  @@index([lastExportedAt])
  @@index([schoolYear, siteCode, itemNo, customerBillTo])
  @@map("customer_bid_data")
  @@schema("ait")
}

model CustomerBidSyncLog {
  id              String    @id @default(uuid())
  status          String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  schoolYear      String    @map("school_year")
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  recordsTotal    Int?      @map("records_total")
  recordsInserted Int?      @map("records_inserted")
  recordsUpdated  Int?      @map("records_updated")
  errorMessage    String?   @map("error_message") @db.Text
  durationMs      Int?      @map("duration_ms")
  triggeredBy     String    @map("triggered_by") // "manual" | "scheduled"

  @@index([schoolYear])
  @@index([status])
  @@map("customer_bid_sync_log")
  @@schema("ait")
}

model CustomerBidExportRun {
  id           String        @id @default(uuid())
  status       String        @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, FAILED
  exportType   BidExportType @map("export_type")
  triggeredBy  String        @map("triggered_by") // "manual" | "scheduled"
  totalRecords Int?          @map("total_records")
  startedAt    DateTime      @default(now()) @map("started_at")
  completedAt  DateTime?     @map("completed_at")
  durationMs   Int?          @map("duration_ms")
  errorMessage String?       @map("error_message") @db.Text

  // Relations
  items CustomerBidExportItem[]

  @@index([status])
  @@index([startedAt])
  @@map("customer_bid_export_run")
  @@schema("ait")
}

model CustomerBidExportItem {
  id             String        @id @default(uuid())
  sourceDb       String        @map("source_db")
  siteCode       String        @map("site_code")
  customerBillTo String        @map("customer_bill_to")
  itemNo         String        @map("item_no")
  schoolYear     String        @map("school_year")
  exportType     BidExportType @map("export_type")
  status         String        @default("QUEUED") // QUEUED, EXPORTED, CANCELLED
  queuedBy       String        @map("queued_by")
  queuedAt       DateTime      @default(now()) @map("queued_at")
  runId          String?       @map("run_id")

  // Relations
  customerBid CustomerBidData      @relation(fields: [sourceDb, siteCode, customerBillTo, itemNo, schoolYear], references: [sourceDb, siteCode, customerBillTo, itemNo, schoolYear])
  exportRun   CustomerBidExportRun? @relation(fields: [runId], references: [id])

  @@index([status])
  @@index([queuedAt])
  @@index([runId])
  @@index([sourceDb, siteCode, customerBillTo, itemNo, schoolYear])
  @@map("customer_bid_export_item")
  @@schema("ait")
}

model ChatLog {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id")
  userEmail           String   @map("user_email")
  question            String   @db.Text
  answer              String   @db.Text
  confidence          Int      @default(0)
  confidenceReasoning String   @map("confidence_reasoning") @db.Text @default("")
  accuracy            Int      @default(0)
  sqlStatus           String   @map("sql_status")
  rawSql              String?  @map("raw_sql") @db.Text
  rawResult           Json?    @map("raw_result")
  sqlInputTokens      Int      @map("sql_input_tokens") @default(0)
  sqlOutputTokens     Int      @map("sql_output_tokens") @default(0)
  answerInputTokens   Int      @map("answer_input_tokens") @default(0)
  answerOutputTokens  Int      @map("answer_output_tokens") @default(0)
  modelName           String   @map("model_name")
  promptId            String   @map("prompt_id")
  responseTimeMs      Int      @map("response_time_ms") @default(0)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  feedbackSentiment   String?  @map("feedback_sentiment")
  feedbackReason      String?  @map("feedback_reason") @db.Text
  feedbackAt          DateTime? @map("feedback_at") @db.Timestamptz

  @@index([userId])
  @@index([createdAt])
  @@map("chat_log")
  @@schema("ait")
}

// ============================================
// SIQ SCHEMA - StockIQ Integration Tables
// ============================================

model SiqReportData {
  siteCode String @map("site_code")
  itemCode String @map("item_code")

  // Planning
  abcClass     String?  @map("abc_class")
  safetyStock  Decimal? @map("safety_stock")
  targetStock  Decimal? @map("target_stock")
  preferredMax Decimal? @map("preferred_max")
  maxStock     Decimal? @map("max_stock")

  // Demand
  openEstimates          Decimal? @map("open_estimates")
  openSalesPlusEstimates Decimal? @map("open_sales_plus_estimates")

  // Forecasts
  currentMonthForecast Decimal? @map("current_month_forecast")
  forecastMonth1       Decimal? @map("forecast_month_1")
  forecastMonth2       Decimal? @map("forecast_month_2")
  forecastMonth3       Decimal? @map("forecast_month_3")
  forecastMonth4       Decimal? @map("forecast_month_4")

  // Metrics (calculated by SIQ)
  weeksSupplyOnhand   Decimal? @map("weeks_supply_onhand")
  weeksOnhandEst      Decimal? @map("weeks_onhand_est")
  forecastVarianceMtd Decimal? @map("forecast_variance_mtd")
  supplyVariance      Decimal? @map("supply_variance")

  // Customer
  totalCustomers      Int?    @map("total_customers")
  top5CustomerShipTos String? @map("top_5_customer_ship_tos") @db.Text

  // Sync metadata
  syncId   String   @map("sync_id")
  syncedAt DateTime @default(now()) @map("synced_at")

  // Relations
  syncLog SiqSyncLog @relation(fields: [syncId], references: [id])

  @@id([siteCode, itemCode])
  @@index([syncId])
  @@index([abcClass])
  @@map("report_data")
  @@schema("siq")
}

model SiqSyncLog {
  id          String    @id @default(uuid())
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Record counts
  recordsTotal    Int? @map("records_total")
  recordsInserted Int? @map("records_inserted")
  recordsUpdated  Int? @map("records_updated")
  recordsDeleted  Int? @map("records_deleted")

  // API response info
  apiResponseStatus Int?    @map("api_response_status")
  apiResponseTimeMs Int?    @map("api_response_time_ms")
  apiErrorMessage   String? @map("api_error_message") @db.Text

  // Error handling (service-level errors)
  errorMessage String? @map("error_message") @db.Text

  // Performance
  durationMs Int? @map("duration_ms")

  // Trigger info
  triggeredBy String @map("triggered_by")

  // Relations
  records SiqReportData[]

  @@index([status])
  @@index([startedAt])
  @@map("sync_log")
  @@schema("siq")
}
