{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.20.0",
  "description": "Admin Panel Backend - Express API with Prisma",
  "main": "dist/index.js",
  "scripts": {
    "predev": "prisma generate",
    "dev": "ts-node-dev -r @aws/aws-distro-opentelemetry-node-autoinstrumentation/register -r tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node -r @aws/aws-distro-opentelemetry-node-autoinstrumentation/register dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:deploy": "prisma migrate deploy",
    "migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.947.0",
    "@aws/aws-distro-opentelemetry-node-autoinstrumentation": "^0.8.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.208.0",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.2.0",
    "@prisma/instrumentation": "^7.1.0",
    "aws-jwt-verify": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.16.0",
    "prisma": "^7.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "vitest": "^3.1.4"
  }
}
