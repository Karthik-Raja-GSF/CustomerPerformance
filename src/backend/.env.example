# Server Configuration
PORT=8887
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ait_procurement"

# CORS Configuration
CORS_ORIGIN=http://localhost:3030

# ===========================================
# OpenTelemetry Configuration
# ===========================================
# The app exports traces, metrics, and logs via OTLP to the configured endpoint.
#
# Local Development:
#   - Uses Aspire Dashboard (run via docker-compose or standalone)
#   - Start: docker run --rm -p 18888:18888 -p 4317:18889 -d --name aspire mcr.microsoft.com/dotnet/aspire-dashboard:9.0
#   - Dashboard UI: http://localhost:18888
#
# Production (ECS):
#   - ADOT Collector sidecar receives OTLP on localhost:4317
#   - Exports to AWS X-Ray (traces), CloudWatch Metrics (metrics), CloudWatch Logs (logs)

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=ait-backend
OTEL_SERVICE_VERSION=1.0.0

# Disable telemetry for testing (optional)
# OTEL_SDK_DISABLED=true

# Service Account Cognito (separate User Pool for M2M access)
# Leave empty for local dev — service account tokens will only verify against the main pool.
# Populated by CDK in deployed environments.
AWS_COGNITO_SVC_USER_POOL_ID=
AWS_COGNITO_SVC_CLIENT_ID=

# RBAC Configuration — Local Development (disabled)
# When disabled, all authenticated users get full access.
RBAC_ENABLED=false
RBAC_GROUP_SALES=
RBAC_GROUP_CATMAN=
RBAC_GROUP_DEMAND_PLANNER=
RBAC_GROUP_PURCHASING=
RBAC_GROUP_EARLY_ADOPTER=
RBAC_GROUP_ADMIN=

# RBAC Configuration — Higher Environments (dev/prd)
# Uncomment below and comment out the block above to test with RBAC locally
# RBAC_ENABLED=true
# RBAC_GROUP_ADMIN=f2e25746-a556-4e57-a31f-735e08ef5cb1
# RBAC_GROUP_SALES=dcdcdc52-d022-44db-b411-dee01c883879
# RBAC_GROUP_CATMAN=ceb05fa2-1f3c-4cd8-95f3-a20f6ef984db
# RBAC_GROUP_DEMAND_PLANNER=a31185f0-c0a8-494c-8883-8dada64e9849
# RBAC_GROUP_PURCHASING=2341154d-ffd2-4c66-9d43-a42737d63f6e
# RBAC_GROUP_EARLY_ADOPTER=9c5aba67-2af0-4e42-b0ed-cab449333bc6

# Jira API Configuration (for Report Issue feature)
# Users can report bugs from the admin panel — reports are sent to Jira as Bug tickets.
# Generate an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=AIT
JIRA_EMAIL=service-account@your-org.com
JIRA_API_TOKEN=
JIRA_TIMEOUT_MS=15000

# Stock IQ Sync configuration
STOCKIQ_USERNAME=username
STOCKIQ_PASSWORD=password
STOCKIQ_SYNC_CRON=0 6 * * * # 6 AM daily

# Customer Bid Sync configuration
CUSTOMER_BID_SYNC_CRON=0 13 * * *  # Daily at 5 AM PST (1 PM UTC)
